{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-push-cleanup-check.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
